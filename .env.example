# =============================================================================
# TagOslo (tagoslo.no) – miljøvariabler
# =============================================================================
# Kopier til .env.local for utvikling. Legg samme variabler i Netlify dashboard.

# --- Supabase (database + fil-lagring, gratis tier) ---
DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[pass]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Mapbox (kart + adressesøk) ---
NEXT_PUBLIC_MAPBOX_TOKEN="pk.din_mapbox_token"

# --- Yr / MET Norway (sol og vær) ---
MET_USER_AGENT="TagOslo/1.0 ms.tery@icloud.com"

# --- App (produksjon) ---
NEXT_PUBLIC_APP_URL="https://tagoslo.no"

# --- Cloudflare Turnstile (anbefalt i prod) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Admin moderering (anbefalt – lag en lang tilfeldig streng) ---
MODERATION_ADMIN_KEY=""

# --- Valgfritt: OpenAI Moderation ---
# OPENAI_API_KEY="sk-..."
